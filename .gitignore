# =============================================================================
# HSEOS Governance — Logs/Audit
# Only .logs/summaries/ content may be committed
# Runs and validation logs are temporary and MUST NOT be versioned
# =============================================================================
.logs/runs/*
!.logs/runs/.gitkeep
.logs/validation/*
!.logs/validation/.gitkeep

# Worktrees — task isolation dirs are never committed
.worktrees/

# Husky
.husky/_/

# NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
