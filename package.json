{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "hseos",
  "version": "1.0.0",
  "description": "HSEOS — Hideaki Software Engineering Operating System. Spec-driven, AI-assisted institutional engineering framework.",
  "keywords": [
    "engineering",
    "ai",
    "agents",
    "governance",
    "framework",
    "hseos",
    "hideaki"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marciohideaki/hseos.git"
  },
  "license": "MIT",
  "author": "Marcio Hideaki",
  "main": "tools/cli/hseos-cli.js",
  "bin": {
    "hseos": "tools/hseos-npx-wrapper.js"
  },
  "scripts": {
    "hseos:install": "node tools/cli/hseos-cli.js install",
    "hseos:uninstall": "node tools/cli/hseos-cli.js uninstall",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,json,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,cjs,mjs,json,yaml}\"",
    "format:fix:staged": "prettier --write",
    "install:hseos": "node tools/cli/hseos-cli.js install",
    "lint": "eslint . --ext .js,.cjs,.mjs,.yaml --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.cjs,.mjs,.yaml --fix",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || exit 0",
    "test": "npm run test:schemas && npm run test:runtime && npm run test:ops && npm run test:cortex && npm run test:install && npm run test:sessions && npm run validate:schemas && npm run lint",
    "test:runtime": "node test/test-mission-execution-runtime.js",
    "test:ops": "node test/test-execution-observability-surface.js && node test/test-ops-approval-actions.js",
    "test:cortex": "node test/test-cortex-recall-intelligence.js",
    "test:install": "node test/test-installation-components.js && node test/test-install-lifecycle.js",
    "test:sessions": "node test/test-session-store.js && node test/test-governance-events.js",
    "test:schemas": "node test/test-agent-schema.js",
    "validate:schemas": "node tools/validate-agent-schema.js"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "npm run lint:fix",
      "npm run format:fix:staged"
    ],
    "*.yaml": [
      "eslint --fix",
      "npm run format:fix:staged"
    ],
    "*.json": [
      "npm run format:fix:staged"
    ]
  },
  "dependencies": {
    "@clack/core": "^1.0.0",
    "@clack/prompts": "^1.0.0",
    "@kayvan/markdown-tree-parser": "^1.6.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "csv-parse": "^6.1.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3",
    "xml2js": "^0.6.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "c8": "^10.1.3",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-unicorn": "^60.0.0",
    "eslint-plugin-yml": "^1.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.1",
    "prettier": "^3.7.4",
    "yaml-eslint-parser": "^1.2.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
